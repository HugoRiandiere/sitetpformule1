            <tr><td>Williams</td><td>Alexander Albon</td><td>Logan Sargeant</td></tr>
            <tr><td>AlphaTauri</td><td>Yuki Tsunoda</td><td>Daniel Ricciardo</td></tr>
            <tr><td>Haas</td><td>Kevin Magnussen</td><td>Nico Hülkenberg</td></tr>
            <tr><td>Alfa Romeo</td><td>Valtteri Bottas</td><td>Guanyu Zhou</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
