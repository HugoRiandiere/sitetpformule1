    <li class="nav-item"><a class="nav-link" href="index.html">ACCUEIL</a></li>
    <li class="nav-item"><a class="nav-link active" href="chronique.html">CHRONIQUE</a></li>
    <style>
        body {
            background: linear-gradient(to right, #111, #1c1c1c);
            color: white;
            font-family: 'Segoe UI', Arial, sans-serif;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        .navbar { 
            border-bottom: 3px solid red; 
        }
        
        .nav-link:hover {
            color: red !important;
            transition: 0.3s;
        }

        .hero-chronique {
            background: linear-gradient(45deg, #b30000, #ff1a1a) !important;
            box-shadow: 0 4px 15px rgba(255, 0, 0, 0.2);
        }

        .card {
            border: none;
            border-radius: 15px;
            transition: 0.3s;
            background-color: #ffffff;
            color: #212529; 
        }

        .card:hover { 
            transform: translateY(-5px); 
        }

        footer { 
            border-top: 3px solid red; 
        }

        .btn-red {
            background-color: red;
            color: white;
            border-radius: 25px;
            border: none;
        }

        .btn-red:hover {
            background-color: #b30000;
            color: white;
        }

        /* Tableau style F1 */
        .table-container {
            margin-top: 2rem;
        }
        table {
            border-collapse: separate;
            border-spacing: 0 10px;
            width: 100%;
            background-color: #fff;
            color: #212529;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        thead tr {
            background: #b30000;
            color: white;
            font-weight: bold;
            font-size: 1.1rem;
        }
        thead th {
            padding: 1rem 1.5rem;
            border: none;
        }
        tbody tr {
            background-color: #f8f9fa;
            transition: background-color 0.3s ease;
            border-radius: 10px;
        }
        tbody tr:hover {
            background-color: #ffe6e6;
        }
        tbody td {
            padding: 1rem 1.5rem;
            vertical-align: middle;
            border: none;
        }
        tbody tr td:first-child {
            font-weight: 700;
            color: #b30000;
        }
    </style>
</head>
